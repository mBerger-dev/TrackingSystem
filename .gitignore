# firmware build outputs (regenerated by `make build`)
firmware/DWM3001C-starter-firmware/Output/
# stashed bench images — build outputs, keep them local. Reproduce an image by
# checking out the commit noted in the milestone entry and rebuilding.
firmware/hex/*.hex
# ...except the SoftDevice: a vendor binary, not built here, and every flash needs it.
!firmware/hex/s112_softdevice.hex
