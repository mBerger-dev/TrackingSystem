        <mxCell id="sBle" value="sensor_ble.[ch]&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;_init / _notify&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8ECFA;strokeColor=#35479B;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#171A1F;" vertex="1" parent="s1">
