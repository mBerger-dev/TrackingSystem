        <mxCell id="sSub" value="Each hardware concern sits behind a two-function module, so the application never calls sd_*, dwt_* or nrfx_* directly (ADR-3)." style="text;html=1;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;fontColor=#5C6470;" vertex="1" parent="s1">
