        </mxCell>

        <mxCell id="pPreempt" value="PREEMPTION   0, 1, 4   &#8594;   6   &#8594;   7   &#8594;   thread mode" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8C93A0;align=left;spacingLeft=12;fontFamily=Courier New;fontSize=12;fontStyle=1;fontColor=#171A1F;" vertex="1" parent="p1">
          <mxGeometry x="40" y="640" width="1005" height="40" as="geometry" />
        </mxCell>

        <mxCell id="pRisk" value="RESIDUAL RISK &#8212; a SoftDevice radio event (pri 0) preempts the pri-6 DW3000 ISR.&lt;br&gt;If that delay pushes past 650 us the exchange is lost. The design ACCEPTS this: that packet carries&lt;br&gt;0xFFFFFFFF and the next attempt follows 50 ms later. Inherent to sharing one CPU with a radio stack." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF1E0;strokeColor=#B85C00;align=left;spacingLeft=12;fontFamily=Helvetica;fontSize=11;fontColor=#171A1F;" vertex="1" parent="p1">
          <mxGeometry x="40" y="690" width="1005" height="70" as="geometry" />
        </mxCell>

        <mxCell id="pOpen" value="OPEN ITEM (M2b): worst-case latency for the pri-6 path is NOT yet measured. Until it is,&#10;&quot;comfortably inside 650 us&quot; is a design expectation, not a verified property." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8A1F1F;dashed=1;align=left;spacingLeft=12;fontFamily=Courier New;fontSize=11;fontColor=#8A1F1F;" vertex="1" parent="p1">
          <mxGeometry x="40" y="770" width="1005" height="45" as="geometry" />
        </mxCell>

        <mxCell id="pRefs" value="Refs: sdk_config.h:1392 (GPIOTE pri 7) &#183; :1920 (NRFX_GPIOTE pri 6) &#183; :6124 (app_timer pri 7)" style="text;html=1;align=left;verticalAlign=middle;fontFamily=Courier New;fontSize=10;fontColor=#5C6470;" vertex="1" parent="p1">
          <mxGeometry x="40" y="822" width="1005" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="3 Software layers" id="software">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
